# Vidmaker3 Bot Environment Configuration
# Copy this file to .env and fill in your values

# === Discord Bot ===
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Cloudflare R2 Storage (for transcript uploads) ===
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_REGION=auto

# === External APIs ===

# OpenAI (for !sum command)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude (for !sum2 command)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# WhisperX API - Your public deployment
WHISPERX_API_URL=https://whisperx.jeffrey-epstein.com

# RapidAPI (optional)
RAPIDAPI_KEY=your-rapidapi-key

# FAL AI (optional)
FAL_KEY=your-fal-key

# === Google Sheets (optional) ===
SPREADSHEET_ID=your_google_spreadsheet_id
GOOGLE_CREDENTIALS_PATH=path/to/credentials.json

# === Webhooks (optional) ===
MAKE_WEBHOOK_URL=https://your-make-webhook.com
TWEET_WEBHOOK_URL=https://your-tweet-webhook.com